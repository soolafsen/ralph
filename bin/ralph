#!/usr/bin/env node
const { spawnSync } = require("child_process");
const fs = require("fs");
const os = require("os");
const path = require("path");

const rawArgs = process.argv.slice(2);
const args = [];
const cwd = process.cwd();
const repoRoot = path.resolve(__dirname, "..");
const globalDir = path.join(repoRoot, ".agents", "ralph");
const localDir = path.join(cwd, ".agents", "ralph");
const skillsRoot = path.join(repoRoot, "skills");
const codexBackendHelperPath = path.join(repoRoot, ".agents", "ralph", "codex-backend.cjs");
let agentOverride = null;
let installSkills = false;
let installForce = false;
let installForceSkills = false;
let prdPath = null;
let progressPath = null;
let prdOutPath = null;
let tinyMode = false;
let barebonesMode = false;
let planPath = null;
let quietMode = true;
let verboseMode = false;
let showBrowser = false;

function exists(p) {
  try {
    fs.accessSync(p);
    return true;
  } catch {
    return false;
  }
}

function loadCodexBackendHelper() {
  if (!exists(codexBackendHelperPath)) return null;
  return require(codexBackendHelperPath);
}

function readPackageMeta() {
  try {
    const pkgPath = path.join(repoRoot, "package.json");
    const data = JSON.parse(fs.readFileSync(pkgPath, "utf-8"));
    return { name: data.name || "ralph", version: data.version || "0.0.0" };
  } catch {
    return { name: "ralph", version: "0.0.0" };
  }
}

function compareVersions(a, b) {
  const parse = (value) =>
    String(value || "")
      .split(".")
      .map((part) => parseInt(part, 10))
      .map((n) => (Number.isNaN(n) ? 0 : n));
  const pa = parse(a);
  const pb = parse(b);
  const len = Math.max(pa.length, pb.length);
  for (let i = 0; i < len; i += 1) {
    const da = pa[i] || 0;
    const db = pb[i] || 0;
    if (da > db) return 1;
    if (da < db) return -1;
  }
  return 0;
}

function checkForUpdate() {
  if (!process.stdout.isTTY || !process.stdin.isTTY) return null;
  if (process.env.RALPH_SKIP_UPDATE_CHECK === "1") return null;
  const { name, version } = readPackageMeta();
  const result = spawnSync("npm", ["view", name, "version"], withWindowsHide({ encoding: "utf-8" }));
  if (result.status !== 0) return null;
  const latest = String(result.stdout || "").trim();
  if (!latest) return null;
  if (compareVersions(latest, version) <= 0) return null;
  return { name, current: version, latest };
}

function usage() {
  console.log(`ralph <command>

Commands:
  install [--skills] [--force] [--force-skills]  Copy .agents/ralph into the current repo
  prd ["<request>"] [--out path]      Generate a PRD (JSON) via agent
  bench:smoke                         Run the smoke Ralph benchmark suite
  bench:quick                         Run the quick Ralph benchmark suite
  bench:hourly                        Run the hourly Ralph benchmark suite
  bench:deep                          Run the deep Ralph benchmark suite
  ping                                Minimal agent health check
  doctor                              Check Ralph runner prerequisites
  log "<message>"                     Append to .ralph/activity.log
  build [n] [--no-commit] [--tiny] [--barebones] [--verbose] [--show-browser]  Run build loop (default)
  overview                            Render a human overview from PRD JSON
  help                                Show this message

Options:
  --prd <path>                        Override PRD path
  --plan <path>                       Use a plan file as PRD input
  --out <path>                        Override PRD output path (prd command)
  --progress <path>                   Override progress log path
  --tiny                              Keep the normal loop, but force the smaller-task prompt path
  --barebones                         Minimal loop mode: single-story-biased with the lightest acceptable verification
  --quiet                             Compatibility alias for the default terse output mode
  --verbose                           Stream full live agent output instead of the default terse mode
  --show-browser                      For browser verification, allow a visible browser window instead of preferring headless checks
  --force-skills                      Reinstall bundled skills even if they exist
  --agent <codex|claude|droid|opencode>  Override agent runner

Notes:
- Uses local .agents/ralph if present; otherwise uses bundled defaults.
- State and logs are written to .ralph/ in the project.
- Normal build is the default for most Ralph work.
- Quiet output is now the default; use --verbose for full live agent output.
- --tiny changes prompt behavior for very small tasks; --barebones is the more minimal loop mode.
- Browser verification still happens by default for frontend work. --show-browser only changes browser visibility for those checks.
- --barebones defaults build runs to one iteration unless you pass an explicit iteration count.
`);
}

function prdUsage() {
  console.log(`ralph prd ["<request>"] [options]

Generate a PRD JSON via agent.

Options:
  --plan <path>   Use a plan file as the PRD source
  --out <path>    Override the output file or directory
  --quiet         Compatibility alias for the default terse output mode
  --verbose       Stream full live agent output instead of the default terse mode
  --agent <name>  Override agent runner

Auto-detect:
  If no request text and no --plan are provided, Ralph looks for:
  - cursor-plan.md
  - plan.md
  - *.plan.md
`);
}

function findPrdCandidates(baseDir) {
  const tasksDir = path.join(baseDir, ".agents", "tasks");
  if (!exists(tasksDir)) {
    return [];
  }
  return fs
    .readdirSync(tasksDir)
    .filter((name) => name.toLowerCase().endsWith(".json"))
    .map((name) => path.join(tasksDir, name));
}

function defaultPrdOutputPath(baseDir, request) {
  return path.join(baseDir, ".agents", "tasks");
}

function skillRootsForAgent(agentName, baseDir) {
  const home = os.homedir();
  switch (agentName) {
    case "codex":
      return [
        path.join(baseDir, ".codex", "skills"),
        path.join(home, ".codex", "skills"),
      ];
    case "claude":
      return [
        path.join(baseDir, ".claude", "skills"),
        path.join(home, ".claude", "skills"),
      ];
    case "droid":
      return [
        path.join(baseDir, ".factory", "skills"),
        path.join(home, ".factory", "skills"),
      ];
    case "opencode":
      return [
        path.join(baseDir, ".opencode", "skills"),
        path.join(home, ".local", "share", "opencode", "skills"),
      ];
    default:
      return [];
  }
}

function findInstalledSkill(agentName, skillName, baseDir) {
  for (const root of skillRootsForAgent(agentName, baseDir)) {
    const candidate = path.join(root, skillName);
    if (exists(candidate)) {
      return candidate;
    }
  }
  return null;
}

function ensureRequiredSkill(agentName, skillName, baseDir) {
  const installed = findInstalledSkill(agentName, skillName, baseDir);
  if (installed) {
    return installed;
  }
  const roots = skillRootsForAgent(agentName, baseDir);
  const listedRoots = roots.length ? roots.join(", ") : "(unknown)";
  console.error(`Missing ${skillName} skill for agent '${agentName}'.`);
  console.error(`Searched: ${listedRoots}`);
  console.error("Run `ralph install --skills` and install skills for the agent you are using.");
  process.exit(1);
}

function findPlanCandidates(baseDir) {
  const explicit = ["cursor-plan.md", "plan.md"]
    .map((name) => path.join(baseDir, name))
    .filter((candidate) => exists(candidate));
  const globbed = fs
    .readdirSync(baseDir, { withFileTypes: true })
    .filter((entry) => entry.isFile() && entry.name.toLowerCase().endsWith(".plan.md"))
    .map((entry) => path.join(baseDir, entry.name));
  return Array.from(new Set([...explicit, ...globbed]));
}

function printPlanSearchDiagnostics(baseDir, candidates) {
  console.log(`Plan search cwd: ${baseDir}`);
  console.log("Plan search patterns: cursor-plan.md, plan.md, *.plan.md");
  if (candidates.length) {
    console.log(`Plan candidates: ${candidates.map((candidate) => path.relative(baseDir, candidate)).join(", ")}`);
  } else {
    console.log("Plan candidates: none");
  }
}

function toBashPath(value) {
  if (typeof value !== "string" || value.length === 0) return value;
  const normalized = value.replace(/\\/g, "/");
  if (/^[A-Za-z]:\//.test(normalized)) {
    return `/${normalized[0].toLowerCase()}${normalized.slice(2)}`;
  }
  return normalized;
}

function resolveBashExecutable() {
  if (process.platform !== "win32") return "bash";
  const candidates = [
    path.join(process.env.ProgramFiles || "C:\\Program Files", "Git", "bin", "bash.exe"),
    path.join(process.env.ProgramFiles || "C:\\Program Files", "Git", "usr", "bin", "bash.exe"),
    path.join(process.env["ProgramFiles(x86)"] || "C:\\Program Files (x86)", "Git", "bin", "bash.exe"),
    path.join(process.env["ProgramFiles(x86)"] || "C:\\Program Files (x86)", "Git", "usr", "bin", "bash.exe"),
  ];
  for (const candidate of candidates) {
    if (exists(candidate)) return candidate;
  }
  return "bash";
}

function withWindowsHide(options = {}) {
  if (process.platform !== "win32") return options;
  return { ...options, windowsHide: true };
}

function commandExists(command) {
  if (process.platform === "win32") {
    return spawnSync("where", [command], withWindowsHide({ stdio: "ignore" })).status === 0;
  }
  return spawnSync(`command -v ${command}`, { shell: true, stdio: "ignore" }).status === 0;
}

function commandOutput(command, args) {
  if (process.platform === "win32") {
    return spawnSync(process.env.ComSpec || "cmd.exe", ["/d", "/s", "/c", `${command} ${args.join(" ")}`], {
      encoding: "utf-8",
      windowsHide: true,
    });
  }
  return spawnSync(command, args, withWindowsHide({ encoding: "utf-8" }));
}

function resolveOptionalModule(moduleName) {
  try {
    return require.resolve(`${moduleName}/package.json`, { paths: [repoRoot] });
  } catch {
    return null;
  }
}

async function resolveCodexBackendDiagnostics(overrides = {}) {
  const helper = loadCodexBackendHelper();
  if (!helper) {
    return {
      requested: "auto",
      selected: "cli",
      sdkAvailable: false,
      sdkDetail: "backend helper missing",
      fallbackReason: "backend helper missing",
      error: "",
    };
  }
  return helper.resolveCodexBackend({
    platform: process.platform,
    env: {
      ...process.env,
      RALPH_AGENT_KIND: "codex",
      RALPH_AGENT_COMMAND_SOURCE: process.env.AGENT_CMD ? "env" : "map",
      ...overrides,
    },
  });
}

function runLoop(loopPath, loopArgs, options) {
  if (process.platform === "win32") {
    const nativeRunner = path.join(path.dirname(loopPath), "windows-runner.cjs");
    if (exists(nativeRunner)) {
      return spawnSync(process.execPath, [nativeRunner, ...loopArgs], withWindowsHide(options));
    }
    const loopPathKeys = new Set([
      "RALPH_ROOT",
      "PRD_PATH",
      "PROGRESS_PATH",
      "AGENTS_PATH",
      "PROMPT_BUILD",
      "GUARDRAILS_PATH",
      "ERRORS_LOG_PATH",
      "ACTIVITY_LOG_PATH",
      "TMP_DIR",
      "RUNS_DIR",
      "GUARDRAILS_REF",
      "CONTEXT_REF",
      "ACTIVITY_CMD",
    ]);
    const bashArgs = [
      toBashPath(loopPath),
      ...loopArgs.map((arg) => (typeof arg === "string" && /^[A-Za-z]:[\\/]/.test(arg) ? toBashPath(arg) : arg)),
    ];
    const env = options && options.env
      ? Object.fromEntries(
          Object.entries(options.env).map(([key, value]) => [
            key,
            loopPathKeys.has(key) && typeof value === "string" ? toBashPath(value) : value,
          ]),
        )
      : options?.env;
    return spawnSync(resolveBashExecutable(), bashArgs, withWindowsHide({ ...options, env }));
  }
  return spawnSync(loopPath, loopArgs, withWindowsHide(options));
}

async function resolvePrdPath({ cwd, explicitPath, label }) {
  if (explicitPath) {
    return path.resolve(cwd, explicitPath);
  }
  const candidates = findPrdCandidates(cwd);
  if (candidates.length === 0) {
    return null;
  }
  if (candidates.length === 1) {
    return candidates[0];
  }
  if (!process.stdin.isTTY || !process.stdout.isTTY) {
    return candidates[0];
  }
  const { intro, select, outro, isCancel } = await import("@clack/prompts");
  intro(label || "Select PRD");
  const selection = await select({
    message: "Pick a PRD JSON file",
    options: candidates.map((file) => ({
      value: file,
      label: path.relative(cwd, file),
    })),
  });
  if (isCancel(selection)) {
    outro("Cancelled.");
    process.exit(0);
  }
  outro("Selected.");
  return selection;
}

async function resolvePlanPath({ cwd, explicitPath }) {
  if (explicitPath) {
    const resolved = path.resolve(cwd, explicitPath);
    if (!exists(resolved)) {
      console.error(`Plan file not found: ${resolved}`);
      process.exit(1);
    }
    return resolved;
  }
  const candidates = findPlanCandidates(cwd);
  if (candidates.length === 0) {
    printPlanSearchDiagnostics(cwd, candidates);
    return null;
  }
  if (!process.stdin.isTTY || !process.stdout.isTTY) {
    return candidates[0];
  }
  if (candidates.length === 1) {
    const candidate = candidates[0];
    const { select, isCancel } = await import("@clack/prompts");
    const choice = await select({
      message: `Use detected plan file ${path.relative(cwd, candidate)}?`,
      options: [
        { value: candidate, label: `Use ${path.relative(cwd, candidate)}` },
        { value: "__manual__", label: "Type request manually" },
      ],
      initialValue: candidate,
    });
    if (isCancel(choice)) {
      process.exit(0);
    }
    return choice === "__manual__" ? null : choice;
  }
  const { select, isCancel } = await import("@clack/prompts");
  const choice = await select({
    message: "Choose a plan file or type the request manually",
    options: [
      ...candidates.map((candidate) => ({
        value: candidate,
        label: path.relative(cwd, candidate),
      })),
      { value: "__manual__", label: "Type request manually" },
    ],
    initialValue: candidates[0],
  });
  if (isCancel(choice)) {
    process.exit(0);
  }
  return choice === "__manual__" ? null : choice;
}

for (let i = 0; i < rawArgs.length; i += 1) {
  const arg = rawArgs[i];
  if (arg.startsWith("--agent=")) {
    agentOverride = arg.split("=").slice(1).join("=");
    continue;
  }
  if (arg === "--agent") {
    agentOverride = rawArgs[i + 1];
    i += 1;
    continue;
  }
  if (arg === "--skills") {
    installSkills = true;
    continue;
  }
  if (arg === "--force") {
    installForce = true;
    continue;
  }
  if (arg === "--force-skills") {
    installForceSkills = true;
    continue;
  }
  if (arg === "--tiny") {
    tinyMode = true;
    continue;
  }
  if (arg === "--barebones") {
    barebonesMode = true;
    continue;
  }
  if (arg === "--quiet") {
    quietMode = true;
    continue;
  }
  if (arg === "--verbose") {
    verboseMode = true;
    quietMode = false;
    continue;
  }
  if (arg === "--show-browser") {
    showBrowser = true;
    continue;
  }
  if (arg.startsWith("--prd=")) {
    prdPath = arg.split("=").slice(1).join("=");
    continue;
  }
  if (arg.startsWith("--plan=")) {
    planPath = arg.split("=").slice(1).join("=");
    continue;
  }
  if (arg.startsWith("--out=")) {
    prdOutPath = arg.split("=").slice(1).join("=");
    continue;
  }
  if (arg === "--prd") {
    prdPath = rawArgs[i + 1];
    i += 1;
    continue;
  }
  if (arg === "--plan") {
    planPath = rawArgs[i + 1];
    i += 1;
    continue;
  }
  if (arg === "--out") {
    prdOutPath = rawArgs[i + 1];
    i += 1;
    continue;
  }
  if (arg.startsWith("--progress=")) {
    progressPath = arg.split("=").slice(1).join("=");
    continue;
  }
  if (arg === "--progress") {
    progressPath = rawArgs[i + 1];
    i += 1;
    continue;
  }
  args.push(arg);
}

const cmd = args[0];
if (cmd === "help" || cmd === "-h" || cmd === "--help") {
  usage();
  process.exit(0);
}

async function runInstallSkills() {
  const { intro, outro, select, isCancel } = await import("@clack/prompts");
  intro("Ralph skills install");

  const agent = await select({
    message: "Which agent are you using?",
    options: [
      { value: "codex", label: "codex" },
      { value: "claude", label: "claude" },
      { value: "droid", label: "droid" },
      { value: "opencode", label: "opencode" },
    ],
    initialValue: agentOverride || "codex",
  });
  if (isCancel(agent)) {
    outro("Cancelled.");
    process.exit(0);
  }

  const scope = await select({
    message: "Where should skills be installed?",
    options: [
      { value: "local", label: "Local (project)" },
      { value: "global", label: "Global (home directory)" },
    ],
    initialValue: "local",
  });
  if (isCancel(scope)) {
    outro("Cancelled.");
    process.exit(0);
  }

  const home = os.homedir();
  const targetRoot =
    agent === "codex"
      ? scope === "global"
        ? path.join(home, ".codex", "skills")
        : path.join(cwd, ".codex", "skills")
      : agent === "claude"
        ? scope === "global"
          ? path.join(home, ".claude", "skills")
          : path.join(cwd, ".claude", "skills")
        : agent === "droid"
          ? scope === "global"
            ? path.join(home, ".factory", "skills")
            : path.join(cwd, ".factory", "skills")
          : scope === "global"
            ? path.join(home, ".local", "share", "opencode", "skills")
            : path.join(cwd, ".opencode", "skills");

  const skillsToInstall = ["commit", "dev-browser", "prd", "prdtest01", "prdtest02", "prdtest03", "prdtest04", "prdtest05", "prdtest06", "prdtest07", "prdtest08", "prdtest09"];
  fs.mkdirSync(targetRoot, { recursive: true });
  const installed = [];
  const skipped = [];

  for (const skill of skillsToInstall) {
    const source = path.join(skillsRoot, skill);
    const target = path.join(targetRoot, skill);
    if (!exists(source)) {
      skipped.push(`${skill} (missing in repo)`);
      continue;
    }
    if (exists(target) && !(installForce || installForceSkills)) {
      skipped.push(`${skill} (already exists)`);
      continue;
    }
    fs.cpSync(source, target, { recursive: true, force: true });
    installed.push(skill);
  }

  if (installed.length) {
    console.log(`Installed skills to ${targetRoot}: ${installed.join(", ")}`);
  }
  if (skipped.length) {
    console.log(`Skipped: ${skipped.join(", ")}`);
  }
  outro("Done.");
}

async function main() {
  const updateInfo = checkForUpdate();
  if (updateInfo) {
    const { intro, confirm, outro, isCancel } = await import("@clack/prompts");
    intro("Ralph update available");
    const shouldUpdate = await confirm({
      message: `Update ${updateInfo.name} from ${updateInfo.current} to ${updateInfo.latest}?`,
      initialValue: true,
    });
    if (isCancel(shouldUpdate)) {
      outro("Skipped update.");
    } else if (shouldUpdate) {
      outro("Updating...");
      const result = spawnSync("npm", ["i", "-g", `${updateInfo.name}@latest`], {
        stdio: "inherit",
        ...(process.platform === "win32" ? { windowsHide: true } : {}),
      });
      process.exit(result.status ?? 1);
    } else {
      outro("Skipped update.");
    }
  }

  if (cmd === "install") {
    if (exists(localDir) && !installForce) {
      console.log(`.agents/ralph already exists at ${localDir}. Skipping templates.`);
    } else {
      if (!exists(globalDir)) {
        console.error(`Bundled templates not found at ${globalDir}.`);
        process.exit(1);
      }
      fs.mkdirSync(path.dirname(localDir), { recursive: true });
      fs.cpSync(globalDir, localDir, { recursive: true, force: true });
      console.log(`Installed .agents/ralph to ${localDir}`);
    }
    const readmeSrc = path.join(repoRoot, "README.md");
    const diagramSrc = path.join(repoRoot, "diagram.svg");
    const imageSrc = path.join(repoRoot, "ralph.webp");
    if (exists(localDir)) {
      const readmeDst = path.join(localDir, "README.md");
      const diagramDst = path.join(localDir, "diagram.svg");
      const imageDst = path.join(localDir, "ralph.webp");
      if (exists(readmeSrc)) fs.copyFileSync(readmeSrc, readmeDst);
      if (exists(diagramSrc)) fs.copyFileSync(diagramSrc, diagramDst);
      if (exists(imageSrc)) fs.copyFileSync(imageSrc, imageDst);
    }
    if (installSkills) {
      await runInstallSkills();
    } else {
      const { confirm, isCancel } = await import("@clack/prompts");
      const wantsSkills = await confirm({
        message: "Install skills (commit + dev-browser + prd)?",
        initialValue: true,
      });
      if (isCancel(wantsSkills)) {
        console.log("Skipped skills install.");
      } else if (wantsSkills) {
        await runInstallSkills();
      }
    }
    process.exit(0);
  }

  if (cmd === "doctor") {
    const home = os.homedir();
    const bashExe = resolveBashExecutable();
    const codexSkills = path.join(home, ".codex", "skills");
    const detectedPlans = findPlanCandidates(cwd);
    const codexPrdLocal = path.join(cwd, ".codex", "skills", "prd");
    const codexPrdGlobal = path.join(home, ".codex", "skills", "prd");
    const codexVersion = commandOutput("codex", ["--version"]);
    const pythonVersion = commandOutput("python", ["--version"]);
    const gitBashPythonVersion = spawnSync(resolveBashExecutable(), ["-lc", "python3 --version"], withWindowsHide({ encoding: "utf-8" }));
    const playwrightPackage = resolveOptionalModule("playwright");
    const codexBackend = await resolveCodexBackendDiagnostics();
    const checks = [
      {
        label: "Git Bash (optional helpers)",
        ok: exists(bashExe),
        detail: exists(bashExe) ? bashExe : "not found",
      },
      {
        label: "Codex CLI",
        ok: commandExists("codex"),
        detail: codexVersion.stdout?.trim() || codexVersion.stderr?.trim() || "not found",
      },
      {
        label: "Codex SDK package",
        ok: codexBackend.sdkAvailable,
        detail: codexBackend.sdkDetail || "not available",
      },
      {
        label: "Codex backend selection",
        ok: true,
        detail: `${codexBackend.selected} (requested ${codexBackend.requested || "auto"})`,
      },
      {
        label: "Codex backend fallback",
        ok: true,
        detail: codexBackend.error || codexBackend.fallbackReason || "none",
      },
      {
        label: "Python (PowerShell)",
        ok: pythonVersion.status === 0,
        detail: pythonVersion.stdout?.trim() || pythonVersion.stderr?.trim() || "not found",
      },
      {
        label: "Python3 (Git Bash, optional)",
        ok: gitBashPythonVersion.status === 0,
        detail: gitBashPythonVersion.stdout?.trim() || gitBashPythonVersion.stderr?.trim() || "not found",
      },
      {
        label: "Bundled templates",
        ok: exists(globalDir),
        detail: globalDir,
      },
      {
        label: "Ralph browser checker",
        ok: Boolean(playwrightPackage),
        detail: playwrightPackage || "playwright package missing",
      },
      {
        label: "Bundled skills",
        ok: exists(skillsRoot),
        detail: skillsRoot,
      },
      {
        label: "Global Codex skills",
        ok: exists(codexSkills),
        detail: codexSkills,
      },
      {
        label: "PRD skill (local Codex)",
        ok: exists(codexPrdLocal),
        detail: codexPrdLocal,
      },
      {
        label: "PRD skill (global Codex)",
        ok: exists(codexPrdGlobal),
        detail: codexPrdGlobal,
      },
      {
        label: "Local templates",
        ok: exists(localDir),
        detail: localDir,
      },
      {
        label: "Plan candidates in cwd",
        ok: true,
        detail: detectedPlans.length
          ? detectedPlans.map((candidate) => path.relative(cwd, candidate)).join(", ")
          : "none",
      },
    ];
    for (const check of checks) {
      console.log(`${check.ok ? "OK " : "!! "} ${check.label}: ${check.detail}`);
    }
    const ok = checks.every((check) =>
      check.ok ||
      check.label === "Codex SDK package" ||
      check.label === "Git Bash (optional helpers)" ||
      check.label === "Python3 (Git Bash, optional)" ||
      check.label === "Local templates" ||
      check.label === "PRD skill (local Codex)" ||
      check.label === "Plan candidates in cwd",
    );
    process.exit(ok ? 0 : 1);
  }

  if (cmd === "bench:smoke" || cmd === "bench:quick" || cmd === "bench:hourly" || cmd === "bench:deep") {
    const suiteId = cmd === "bench:smoke"
      ? "smoke"
      : cmd === "bench:hourly"
        ? "hourly"
        : cmd === "bench:quick"
          ? "quick"
          : "deep";
    const suiteRunner = path.join(repoRoot, "scripts", "run-ralph-benchmark-suite.mjs");
    if (!exists(suiteRunner)) {
      console.error(`Benchmark suite runner not found: ${suiteRunner}`);
      process.exit(1);
    }
    const result = spawnSync(process.execPath, [suiteRunner, "--suite", suiteId], {
      stdio: "inherit",
      env: {
        ...process.env,
        RALPH_SKIP_UPDATE_CHECK: "1",
      },
    });
    process.exit(result.status ?? 1);
  }

  const templateDir = exists(localDir) ? localDir : globalDir;
  if (!exists(templateDir)) {
    console.error("No .agents/ralph found locally and no bundled defaults available.");
    process.exit(1);
  }
  if (templateDir === localDir) {
    console.log(`Using local templates: ${localDir}`);
    console.log("Local templates override bundled global templates for this repo.");
  } else {
    console.log(`Using bundled templates: ${globalDir}`);
  }

  const loopPath = path.join(templateDir, "loop.sh");
  if (!exists(loopPath)) {
    console.error(`loop.sh not found at ${loopPath}`);
    process.exit(1);
  }

  const loopArgs = args.length ? [...args] : ["build"];
  const hasExplicitBuildIterations =
    loopArgs[0] === "build" && loopArgs.slice(1).some((value) => /^\d+$/.test(value));
  if (barebonesMode && loopArgs[0] === "build" && !hasExplicitBuildIterations) {
    loopArgs.splice(1, 0, "1");
  }
  const loadAgentMap = () => {
    const defaults = {
      codex: "codex exec --yolo --skip-git-repo-check -c model_reasoning_effort=\"medium\" -",
      claude: "claude -p --dangerously-skip-permissions \"$(cat {prompt})\"",
      droid: "droid exec --skip-permissions-unsafe -f {prompt}",
      opencode: "opencode run \"$(cat {prompt})\"",
    };
    const interactiveDefaults = {
      codex: "codex exec --yolo --skip-git-repo-check -c model_reasoning_effort=\"medium\" {prompt}",
      claude: "claude --dangerously-skip-permissions {prompt}",
      droid: "droid --skip-permissions-unsafe {prompt}",
      opencode: "opencode --prompt {prompt}",
    };
    const agentsPath = path.join(templateDir, "agents.sh");
    if (!exists(agentsPath)) {
      return {
        headless: defaults,
        interactive: interactiveDefaults,
        defaultAgent: "codex",
      };
    }
    const safePath = agentsPath.replace(/'/g, "'\\''");
    const bashCmd = [
      `source '${safePath}'`,
      'printf "DEFAULT_AGENT=%s\\n" "${DEFAULT_AGENT:-}"',
      'printf "AGENT_CODEX_CMD=%s\\n" "${AGENT_CODEX_CMD:-}"',
      'printf "AGENT_CLAUDE_CMD=%s\\n" "${AGENT_CLAUDE_CMD:-}"',
      'printf "AGENT_DROID_CMD=%s\\n" "${AGENT_DROID_CMD:-}"',
      'printf "AGENT_OPENCODE_CMD=%s\\n" "${AGENT_OPENCODE_CMD:-}"',
      'printf "AGENT_CODEX_INTERACTIVE_CMD=%s\\n" "${AGENT_CODEX_INTERACTIVE_CMD:-}"',
      'printf "AGENT_CLAUDE_INTERACTIVE_CMD=%s\\n" "${AGENT_CLAUDE_INTERACTIVE_CMD:-}"',
      'printf "AGENT_DROID_INTERACTIVE_CMD=%s\\n" "${AGENT_DROID_INTERACTIVE_CMD:-}"',
      'printf "AGENT_OPENCODE_INTERACTIVE_CMD=%s\\n" "${AGENT_OPENCODE_INTERACTIVE_CMD:-}"',
    ].join("; ");
    const result = spawnSync("bash", ["-lc", bashCmd], withWindowsHide({ encoding: "utf-8" }));
    if (result.status !== 0) {
      return {
        headless: defaults,
        interactive: interactiveDefaults,
        defaultAgent: "codex",
      };
    }
    const parsed = new Map();
    for (const line of String(result.stdout || "").split("\n")) {
      if (!line) continue;
      const idx = line.indexOf("=");
      if (idx === -1) continue;
      parsed.set(line.slice(0, idx), line.slice(idx + 1));
    }
    const readVar = (name) => parsed.get(name) || null;
    return {
      headless: {
        codex: readVar("AGENT_CODEX_CMD") || defaults.codex,
        claude: readVar("AGENT_CLAUDE_CMD") || defaults.claude,
        droid: readVar("AGENT_DROID_CMD") || defaults.droid,
        opencode: readVar("AGENT_OPENCODE_CMD") || defaults.opencode,
      },
      interactive: {
        codex: readVar("AGENT_CODEX_INTERACTIVE_CMD") || interactiveDefaults.codex,
        claude: readVar("AGENT_CLAUDE_INTERACTIVE_CMD") || interactiveDefaults.claude,
        droid: readVar("AGENT_DROID_INTERACTIVE_CMD") || interactiveDefaults.droid,
        opencode: readVar("AGENT_OPENCODE_INTERACTIVE_CMD") || interactiveDefaults.opencode,
      },
      defaultAgent: readVar("DEFAULT_AGENT") || "codex",
    };
  };
  const agentDefs = loadAgentMap();
  const agentMap = agentDefs.headless;
  const agentInteractiveMap = agentDefs.interactive;
  const defaultAgent = agentDefs.defaultAgent || "codex";
  const selectedAgent = agentOverride || defaultAgent;
  const selectedAgentSource = agentOverride ? "map" : process.env.AGENT_CMD ? "env" : "map";
  if (agentOverride) {
    const mapped = agentMap[agentOverride];
    if (!mapped) {
      console.error(`Unknown agent: ${agentOverride}`);
      console.error("Valid values: codex, claude, droid, opencode");
      process.exit(1);
    }
    process.env.AGENT_CMD = mapped;
  }
  const env = { ...process.env, RALPH_ROOT: cwd };
  if (!env.ACTIVITY_CMD) {
    env.ACTIVITY_CMD = "ralph log";
  }
  if (progressPath) env.PROGRESS_PATH = progressPath;
  if (tinyMode) env.TINY_TASK_MODE_OVERRIDE = "true";
  if (barebonesMode) env.BAREBONES_MODE_OVERRIDE = "true";
  env.RALPH_QUIET = verboseMode ? "0" : "1";
  if (showBrowser) env.RALPH_BROWSER_VISIBILITY = "show";
  if (templateDir === globalDir) {
    env.PROMPT_BUILD = path.join(templateDir, "PROMPT_build.md");
    env.GUARDRAILS_REF = path.join(templateDir, "references", "GUARDRAILS.md");
    env.CONTEXT_REF = path.join(templateDir, "references", "CONTEXT_ENGINEERING.md");
  }
  env.RALPH_AGENT_KIND = selectedAgent;
  env.RALPH_AGENT_COMMAND_SOURCE = selectedAgentSource;
  if (selectedAgent === "codex" && selectedAgentSource !== "env") {
    env.RALPH_CODEX_MODEL_REASONING_EFFORT = env.RALPH_CODEX_MODEL_REASONING_EFFORT || "medium";
    env.RALPH_CODEX_APPROVAL_POLICY = env.RALPH_CODEX_APPROVAL_POLICY || "never";
    env.RALPH_CODEX_SANDBOX_MODE = env.RALPH_CODEX_SANDBOX_MODE || "danger-full-access";
    env.RALPH_CODEX_SKIP_GIT_REPO_CHECK = env.RALPH_CODEX_SKIP_GIT_REPO_CHECK || "1";
  }

  if (cmd === "ping") {
    const agentName = selectedAgent;
    const agentCmd = agentMap[agentName];
    if (!agentCmd) {
      console.error("Unknown agent for ping.");
      process.exit(1);
    }
    const agentBin = agentCmd.split(" ")[0];
    if (!commandExists(agentBin)) {
      console.error(`Agent command not found: ${agentBin}`);
      process.exit(1);
    }
    const promptFile = path.join(os.tmpdir(), `ralph-ping-${Date.now()}.txt`);
    fs.writeFileSync(promptFile, "Reply with <end>pong</end> only.");
    const escapePath = (value) => `'${String(value).replace(/'/g, "'\\''")}'`;
    const rendered = agentCmd.includes("{prompt}")
      ? agentCmd.replace(/\{prompt\}/g, escapePath(promptFile))
      : `cat ${escapePath(promptFile)} | ${agentCmd}`;
    const result = spawnSync(rendered, withWindowsHide({ shell: true, encoding: "utf-8" }));
    const output = `${result.stdout || ""}${result.stderr || ""}`;
    if (!output.includes("<end>pong</end>")) {
      console.error("Ping failed: missing <end>pong</end>.");
      process.exit(1);
    }
    console.log("Ping OK.");
    process.exit(0);
  }

  if (cmd === "plan") {
    console.error("The plan command has been removed. Use `ralph build` with a JSON PRD.");
    process.exit(1);
  }

  if (cmd === "log") {
    const message = args.slice(1).join(" ").trim();
    if (!message) {
      console.error('Usage: ralph log "message"');
      process.exit(1);
    }
    const activityLog = path.join(cwd, ".ralph", "activity.log");
    fs.mkdirSync(path.dirname(activityLog), { recursive: true });
    const now = new Date();
    const pad = (n) => String(n).padStart(2, "0");
    const stamp = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())} ${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
    fs.appendFileSync(activityLog, `[${stamp}] ${message}\n`);
    process.exit(0);
  }

  if (cmd === "prd") {
    if (args[1] === "--help" || args[1] === "-h") {
      prdUsage();
      process.exit(0);
    }
    let request = args.slice(1).join(" ").trim();
    const resolvedPlanPath = request ? null : await resolvePlanPath({ cwd, explicitPath: planPath });
    if (resolvedPlanPath) {
      request = fs.readFileSync(resolvedPlanPath, "utf-8").trim();
      if (!request) {
        console.error(`Plan file is empty: ${resolvedPlanPath}`);
        process.exit(1);
      }
      console.log(`Using plan file: ${path.relative(cwd, resolvedPlanPath)}`);
    }
    if (!request) {
      const { intro, outro, text, isCancel } = await import("@clack/prompts");
      intro("Ralph PRD");
      const response = await text({
        message: "Describe the feature you want a PRD for",
        placeholder: "Example: A lightweight uptime monitor with email alerts",
      });
      if (isCancel(response)) {
        outro("Cancelled.");
        process.exit(0);
      }
      request = String(response || "").trim();
      if (!request) {
        outro("No description provided.");
        process.exit(1);
      }
      outro("Generating PRD...");
    }
    const requestFile = path.join(os.tmpdir(), `ralph-prd-${Date.now()}.md`);
    fs.writeFileSync(requestFile, `${request}\n`);
    const outputPath = prdOutPath || prdPath || defaultPrdOutputPath(cwd, request);
    env.PRD_PATH = outputPath;
    const agentName = agentOverride || defaultAgent;
    ensureRequiredSkill(agentName, "prd", cwd);
    const prdAgent = agentInteractiveMap[agentName] || agentMap[agentName];
    if (prdAgent) {
      env.PRD_AGENT_CMD = prdAgent;
    }
    const prdArgs = ["prd", "--prompt", requestFile];
    const result = runLoop(loopPath, prdArgs, {
      stdio: "inherit",
      env,
    });
    process.exit(result.status ?? 1);
  }

  if (cmd === "overview") {
    const resolvedPrdPath = await resolvePrdPath({
      cwd,
      explicitPath: prdPath,
      label: "Ralph overview",
    });
    if (!resolvedPrdPath) {
      console.error("No PRD JSON files found. Run `ralph prd` first.");
      process.exit(1);
    }
    const prdText = fs.readFileSync(resolvedPrdPath, "utf-8");
    let prd;
    try {
      prd = JSON.parse(prdText);
    } catch (err) {
      const message = err instanceof Error ? err.message : String(err);
      console.error(`Invalid PRD JSON: ${message}`);
      process.exit(1);
    }
    const stories = Array.isArray(prd.stories) ? prd.stories : [];
    const total = stories.length;
    const done = stories.filter((s) => String(s.status || "open").toLowerCase() === "done").length;
    const inProgress = stories.filter((s) => String(s.status || "open").toLowerCase() === "in_progress").length;
    const open = total - done - inProgress;
    const gates = Array.isArray(prd.qualityGates) ? prd.qualityGates : [];
    const parsed = path.parse(resolvedPrdPath);
    const overviewPath = path.join(parsed.dir, `${parsed.name}.overview.md`);

    const lines = [];
    lines.push(`# PRD Overview${prd.project ? `: ${prd.project}` : ""}`);
    lines.push("");
    lines.push(`- File: ${path.relative(cwd, resolvedPrdPath)}`);
    lines.push(`- Stories: ${total} total (${open} open, ${inProgress} in_progress, ${done} done)`);
    lines.push("");
    lines.push("## Quality Gates");
    if (gates.length === 0) {
      lines.push("- (none)");
    } else {
      for (const gate of gates) lines.push(`- ${gate}`);
    }
    lines.push("");
    lines.push("## Stories");
    if (total === 0) {
      lines.push("- (none)");
    } else {
      for (const story of stories) {
        const status = String(story.status || "open").toLowerCase();
        const depends = Array.isArray(story.dependsOn) && story.dependsOn.length
          ? ` (depends on: ${story.dependsOn.join(", ")})`
          : "";
        lines.push(`- [${status}] ${story.id || "US-???"}: ${story.title || ""}${depends}`);
      }
    }
    fs.writeFileSync(overviewPath, `${lines.join("\n")}\n`);
    console.log(`Overview written to ${path.relative(cwd, overviewPath)}`);
    process.exit(0);
  }

  const needsPrd = cmd === "build" || !cmd;
  if (needsPrd) {
    const resolvedPrdPath = await resolvePrdPath({
      cwd,
      explicitPath: prdPath,
      label: "Ralph build",
    });
    if (!resolvedPrdPath) {
      console.error("No PRD JSON files found. Run `ralph prd` first.");
      process.exit(1);
    }
    env.PRD_PATH = resolvedPrdPath;
  }

  const result = runLoop(loopPath, loopArgs, {
    stdio: "inherit",
    env,
  });

  process.exit(result.status ?? 1);
}

main().catch((err) => {
  console.error(err);
  process.exit(1);
});
