{
  "name": "@soolafsen/ralph",
  "version": "0.1.3",
  "description": "Minimal, file-based agent loop for autonomous coding.",
  "bin": {
    "ralph": "bin/ralph"
  },
  "scripts": {
    "bench:smoke": "node scripts/run-ralph-benchmark-suite.mjs --suite smoke",
    "bench:quick": "node scripts/run-ralph-benchmark-suite.mjs --suite quick",
    "bench:hourly": "node scripts/run-ralph-benchmark-suite.mjs --suite hourly",
    "bench:deep": "node scripts/run-ralph-benchmark-suite.mjs --suite deep",
    "test": "node tests/cli-smoke.mjs && node tests/process-helper.mjs && node tests/agent-loops.mjs && node tests/codex-sdk-backend.mjs && node tests/recipe-memory.mjs && node tests/stuck-loop-detection.mjs",
    "benchmark:run": "node scripts/analyze-ralph-run.mjs",
    "benchmark:record": "node scripts/record-ralph-benchmark.mjs",
    "benchmark:compare": "node scripts/compare-ralph-benchmark.mjs",
    "benchmark:suite": "node scripts/compare-ralph-suite.mjs",
    "test:real": "node tests/real-agents.mjs",
    "test:ping": "node tests/agent-ping.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@openai/codex-sdk": "^0.116.0",
    "playwright": "^1.54.2"
  },
  "license": "MIT"
}
